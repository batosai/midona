<!DOCTYPE html>
<html>

  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title inertia>
      AdonisJS x Inertia x VueJS
    </title>

    @vite(['inertia/app/app.ts', `inertia/pages/${page.component}.vue`])
    @inertiaHead()
  </head>

  <body class="w-screen min-h-screen font-sans bg-surface-50 dark:bg-surface-950">
    @inertia()
  </body>

</html>
