{
  "extends": "@adonisjs/tsconfig/tsconfig.client.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "module": "ESNext",
    "jsxImportSource": "vue",
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./components/*"]
    },
    "types": ["vidstack/vue"]
  },
  "include": ["./**/*.ts", "./**/*.vue"]
}
